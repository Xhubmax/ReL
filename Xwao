-- دالة إرسال التنبيه للديسكورد
local function sendWebhook(title, description)
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = 16711680, -- لون أحمر
            ["footer"] = {["text"] = "Xwao Logs"}
        }}
    }
    pcall(function()
        request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- دالة التنبيه على الشاشة (كما هي)
local function notify(text)
    local label = Instance.new("TextLabel", LocalPlayer:WaitForChild("PlayerGui"):FindFirstChildOfClass("ScreenGui"))
    label.Size, label.Position = UDim2.new(0, 200, 0, 50), UDim2.new(0.5, -100, 0.8, 0)
    label.BackgroundColor3, label.Text = Color3.fromRGB(0, 0, 0), text
    label.TextColor3, label.TextSize = Color3.new(1, 1, 1), 18
    Instance.new("UICorner", label)
    task.wait(2)
    label:Destroy()
end

-- بناء الواجهة
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size, Frame.Position = UDim2.new(0, 160, 0, 200), UDim2.new(0.5, -80, 0.3, 0)
Frame.BackgroundColor3, Frame.Active, Frame.Draggable = Color3.fromRGB(20, 20, 20), true, true
Instance.new("UICorner", Frame)

local states = {Harvest = false, Steal = false}

local function createBtn(name, pos)
    local btn = Instance.new("TextButton", Frame)
    btn.Size, btn.Position = UDim2.new(0, 140, 0, 30), UDim2.new(0, 10, 0, pos)
    btn.Text, btn.BackgroundColor3 = name .. ": OFF", Color3.fromRGB(50, 50, 50)
    btn.MouseButton1Click:Connect(function()
        states[name] = not states[name]
        btn.Text = states[name] and name .. ": ON" or name .. ": OFF"
        btn.BackgroundColor3 = states[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

createBtn("Harvest", 20); createBtn("Steal", 60)

-- الحلقة الرئيسية
