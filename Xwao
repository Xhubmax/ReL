    btn.MouseButton1Click:Connect(function()
        states[name] = not states[name]
        btn.Text = states[name] and (name:upper() .. ": ON") or ("AUTO " .. name:upper() .. ": OFF")
        btn.BackgroundColor3 = states[name] and Color3.fromRGB(50, 205, 50) or Color3.fromRGB(138, 43, 226)
    end)
end

