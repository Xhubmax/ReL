local Workspace = game:GetService("Workspace")
local LocalPlayer = game:GetService("Players").LocalPlayer
local HttpService = game:GetService("HttpService")

-- ضع رابط الـ Webhook الخاص بك هنا
local WebhookURL = "YOUR_WEBHOOK_URL_HERE"

local Config = {
    Steal = {"steal"}, -- أضفت الـ Steal للـ Config
    Gold = {"gold seed", "gold", "claim"}, 
    Rainbow = {"rainbow seed", "rainbow", "claim"}
}

-- دالة إرسال التنبيه
local function sendWebhook(msg)
    local data = {["content"] = "🔔 **Notification:** " .. msg}
    local request = syn and syn.request or http_request or request
    pcall(function() request({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
end

-- إرسال تنبيه عند تشغيل السكربت لأول مرة
sendWebhook("السكربت تم تشغيله من قبل: " .. LocalPlayer.Name)

-- [ نظام ESP ] --
local function createESP(part, color)
    if part:FindFirstChild("MyESP") then return end
    local box = Instance.new("BoxHandleAdornment", part)
    box.Name = "MyESP"
    box.Adornee = part
    box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
    box.Color3 = color
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Transparency = 0.3
end

-- واجهة التحكم
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size, Frame.Position = UDim2.new(0, 220, 0, 300), UDim2.new(0.5, -110, 0.4, 0)
Frame.BackgroundColor3, Frame.Active, Frame.Draggable = Color3.fromRGB(30, 15, 40), true, true
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

local states = {Gold = false, Rainbow = false, Steal = false}

local function createBtn(name, pos, color, isAuto)
    local btn = Instance.new("TextButton", Frame)
    btn.Size, btn.Position = UDim2.new(0, 180, 0, 40), UDim2.new(0, 20, 0, pos)
    btn.Text, btn.BackgroundColor3 = (isAuto and "AUTO " or "ESP ") .. name:upper() .. ": OFF", Color3.fromRGB(138, 43, 226)
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        states[name] = not states[name]
        btn.Text = states[name] and ((isAuto and "AUTO " or "ESP ") .. name:upper() .. ": ON") or ((isAuto and "AUTO " or "ESP ") .. name:upper() .. ": OFF")
        btn.BackgroundColor3 = states[name] and color or Color3.fromRGB(138, 43, 226)
        
        -- إرسال تنبيه عند تفعيل الـ Steal
        if name == "Steal" and states.Steal then
            sendWebhook("تم تفعيل ميزة Auto Steal من قبل: " .. LocalPlayer.Name)
        end
    end)
end

createBtn("Gold", 40, Color3.fromRGB(255, 215, 0), false)
createBtn("Rainbow", 90, Color3.fromRGB(0, 255, 255), false)
createBtn("Steal", 140, Color3.fromRGB(255, 0, 0), true)

