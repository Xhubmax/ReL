local function createBtn(name, pos)
    local btn = Instance.new("TextButton", Frame)
    btn.Size, btn.Position = UDim2.new(0, 180, 0, 40), UDim2.new(0, 20, 0, pos)
    btn.Text, btn.BackgroundColor3 = "AUTO " .. name:upper() .. ": OFF", Color3.fromRGB(138, 43, 226)
