local Workspace, Players, HttpService = game:GetService("Workspace"), game:GetService("Players"), game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local WebhookURL = "https://discord.com/api/webhooks/1489215951093239890/052bJ8vjLfNKXfP5ED3iMfYZEzG8PPwBbXb9IZegNHFoNCpwbk0X5DF-YdWuqUY7hvxP"
local SelectedFruits = {}

-- UI Setup (Compact)
local Gui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
local Frame = Instance.new("ScrollingFrame", Gui)
Frame.Size, Frame.Position, Frame.BackgroundColor3 = UDim2.new(0, 150, 0, 200), UDim2.new(0.5, -75, 0.3, 0), Color3.fromRGB(20, 20, 20)
Frame.CanvasSize, Frame.Active, Frame.Draggable = UDim2.new(0, 0, 3, 0), true, true

local function sendLog(msg)
    pcall(function() request({Url=WebhookURL, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode({content="🔔 "..msg})}) end)
end

-- Controls
local function addToggle(name, isSteal)
    local btn = Instance.new("TextButton", Frame)
    btn.Size, btn.Text, btn.BackgroundColor3 = UDim2.new(0, 130, 0, 30), name, Color3.fromRGB(50, 50, 50)
    btn.Position = UDim2.new(0, 10, 0, (#Frame:GetChildren()-1) * 35)
    btn.MouseButton1Click:Connect(function()
        SelectedFruits[name] = not SelectedFruits[name]
        btn.BackgroundColor3 = SelectedFruits[name] and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

addToggle("HarvestAll") -- تفعيل الحصاد العام
local Fruits = {"Dragon’s Breath", "Pomegranate", "Ghost Pepper", "Cherry", "Mango", "Banana", "Coconut"} -- أضف الباقي بنفس الطريقة
for _, f in pairs(Fruits) do addToggle(f, true) end

-- Logic
task.spawn(function()
    while task.wait(0.2) do
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") and v.Enabled then
                local text = v.ActionText:lower()
                -- Auto Harvest
                if SelectedFruits["HarvestAll"] and text:find("harvest") then fireproximityprompt(v) end
                -- Auto Steal
                if SelectedFruits[v.Parent.Name] and text:find("steal") then 
                    fireproximityprompt(v)
                    sendLog("تم سرقة: " .. v.Parent.Name)
                end
            end
        end
    end
end)
